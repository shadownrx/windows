{
  "rewrites": [
    {
      "source": "/nex-music",
      "destination": "/nex-music.html"
    },
    {
      "source": "/nex-music/",
      "destination": "/nex-music.html"
    },
    {
      "source": "/share",
      "destination": "/api/og-nex-music"
    },
    {
      "source": "/p/:code",
      "destination": "/api/og-nex-music?p=:code"
    }
  ],
  "redirects": [
    {
      "source": "/nex-music.html",
      "destination": "/nex-music",
      "permanent": true
    }
  ],
  "functions": {
    "api/spotify-playlist.js": {
      "maxDuration": 30
    },
    "api/playlist-share.js": {
      "maxDuration": 30
    }
  }
}
