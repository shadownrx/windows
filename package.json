{
  "name": "windows",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "music:server": "npm --prefix server run dev",
    "music:server:start": "npm --prefix server start",
    "dev:music": "npm run music:server",
    "build": "npm run build:as && tsc -b && vite build",
    "build:as": "asc assembly/index.ts --target release",
    "lint": "eslint .",
    "preview": "vite preview",
    "sdk:build": "npm run build --workspace=@nex-os/sdk",
    "sdk:publish": "npm publish --workspace=@nex-os/sdk --access public"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.322",
    "@monaco-editor/react": "^4.7.0",
    "@nex-os/sdk": "*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.110.2",
    "@types/three": "^0.183.1",
    "buffer": "^6.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.11.1",
    "isomorphic-git": "^1.38.7",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.17",
    "@vitejs/plugin-react": "^6.0.1",
    "assemblyscript": "^0.28.14",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
